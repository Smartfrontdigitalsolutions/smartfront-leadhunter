# ─── SmartFront LeadHunter — Environment Variables ───────────────────────────
# Copy this to .env for local dev
# In Railway: add these in the Variables panel

# ── Outscraper (Google Maps scraping) ──────────────────────────────────────
OUTSCRAPER_API_KEY=your_outscraper_api_key_here

# ── Airtable ───────────────────────────────────────────────────────────────
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=LeadHunter Leads

# ── Pipeline Settings ──────────────────────────────────────────────────────

# Minimum lead score to save (0-100). Recommended: 45
# HOT leads = 85+, WARM = 65-84, COOL = 45-64
MIN_LEAD_SCORE=45

# Number of businesses to pull per Outscraper query
RESULTS_PER_QUERY=20

# Cron schedule (UTC). Default = 3 PM UTC = 8 AM PDT Las Vegas
# "0 15 * * *"  = 8 AM PDT (summer)
# "0 16 * * *"  = 8 AM PST (winter)
CRON_SCHEDULE=0 15 * * *

# Set to "true" to trigger a run immediately on startup (useful for Railway first deploy)
RUN_NOW=false
